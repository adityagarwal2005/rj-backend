# --- Django core ---
DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database (Supabase Postgres) ---
# Use the "Session pooler" URI from Supabase project settings -> Database ->
# Connect. The direct db.<ref>.supabase.co host is IPv6-only on most Supabase
# projects now and will fail to resolve on an IPv4-only network (which is most
# local/dev networks) - the pooler host below is IPv4-proxied and works everywhere.
DATABASE_URL=postgresql://postgres.xxxxxxxxxxxx:your-db-password@aws-1-ap-south-1.pooler.supabase.com:5432/postgres

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- JWT ---
ACCESS_TOKEN_LIFETIME_MINUTES=60
REFRESH_TOKEN_LIFETIME_DAYS=7

# --- Supabase Storage (S3-compatible) for product images ---
# Supabase project -> Settings -> Storage -> S3 connection
SUPABASE_STORAGE_ENDPOINT_URL=https://xxxxxxxxxxxx.storage.supabase.co/storage/v1/s3
SUPABASE_STORAGE_REGION=ap-south-1
SUPABASE_STORAGE_BUCKET_NAME=product-images
SUPABASE_STORAGE_ACCESS_KEY_ID=your-s3-access-key
SUPABASE_STORAGE_SECRET_ACCESS_KEY=your-s3-secret-key

# --- Email (Resend, via django-anymail; console backend in dev unless this is set) ---
# Get this from https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here
# Must be on a domain you've verified in Resend, or Resend's onboarding sender.
DEFAULT_FROM_EMAIL=RajwadiTukda <no-reply@rajwaditukda.com>

# --- Payments (prepaid via manual UPI/bank transfer) ---
# Shown to customers at checkout so they can pay you directly; not secrets,
# but real business details you should fill in before going live.
PAYMENT_UPI_ID=your-upi-id@bank
PAYMENT_BANK_ACCOUNT_NAME=RajwadiTukda
PAYMENT_BANK_ACCOUNT_NUMBER=0000000000
PAYMENT_BANK_IFSC=XXXX0000000
PAYMENT_BANK_NAME=Your Bank Name
# Full number with country code, no '+' or spaces (e.g. 919999999999) - used to
# build the wa.me link for WhatsApp checkout.
PAYMENT_WHATSAPP_NUMBER=910000000000

# --- Razorpay (optional; leave blank until KYC/signup is complete) ---
# Test Mode keys are available immediately after signup at
# https://dashboard.razorpay.com/app/keys, no KYC needed - Live Mode keys
# only activate after Razorpay approves your KYC. Webhook secret is set when
# you add a webhook pointing at /api/payments/razorpay/webhook/ in the
# Dashboard (Settings -> Webhooks).
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
